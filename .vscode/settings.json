{
    // --- CRS AL Naming Rules ---
    "CRS.RenameWithGit": false,
    "CRS.OnSaveAlFileAction": "Rename",
    "CRS.FileNamePatternExtensions": "<ObjectId>.<BaseId>.CP.<ObjectNameShort>.<ObjectTypeShortPascalCase>.al",
    "CRS.FileNamePattern": "<ObjectId>.CP.<ObjectNameShort>.<ObjectTypeShortPascalCase>.al",    
    "CRS.ExtensionObjectNamePattern": "",
    "CRS.FileNamePatternPageCustomizations": "<ObjectTypeShort><BaseId>-CP.PageCust.<ObjectNameShort>.al",

    // --- AL Code Analyzers ---
    "al.enableCodeAnalysis": true,
    "al.codeAnalyzers":     
    [
        "${CodeCop}",
        "${PerTenantExtensionCop}",
        "${UICop}"
    ],
    "al.ruleSetPath": "./.vscode/custom.ruleset.json",
    "al.packageCachePath": ".alpackages",

    // --- AL Outline Tooltip Templates ---
    "alOutline.defaultAppArea": "All",
    "alOutline.pageActionToolTip" :"Executes the %1 action.",
    "alOutline.pageFieldToolTip": "%Caption%",
    "[al]": {
        "editor.formatOnSave": true
    },

